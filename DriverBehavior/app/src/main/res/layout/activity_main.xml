<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:paddingBottomWithSystemWindowInsets='@{0f}'
        app:paddingTopWithSystemWindowInsets='@{0f}'
        app:paddingLeftWithSystemWindowInsets='@{0f}'
        app:paddingRightWithSystemWindowInsets='@{0f}'>

        <ScrollView
            android:id="@+id/chart_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fadeScrollbars="true"
            android:scrollbars="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/instant_info_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:text="@string/instant"
                    android:textSize="@dimen/big_text_size"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/instant_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/chart_min_height" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ongoing_info_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:text="@string/ongoing"
                    android:textSize="@dimen/big_text_size"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/ongoing_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/chart_min_height" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/last_info_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:text="@string/last"
                    android:textSize="@dimen/big_text_size"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/last_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/chart_min_height" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/combined_info_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:text="@string/combined"
                    android:textSize="@dimen/big_text_size"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/combined_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/chart_min_height" />

            </LinearLayout>

        </ScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
