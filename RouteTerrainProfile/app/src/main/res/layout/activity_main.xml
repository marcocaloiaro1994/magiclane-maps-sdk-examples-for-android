<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">

        <com.magiclane.sdk.core.GemSurfaceView
            android:id="@+id/gem_surface_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/route_profile_scroll_view"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintVertical_weight="0.5" />

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:title="@string/app_name"
            app:titleTextColor="@color/on_primary"
            app:paddingTopWithSystemWindowInsets='@{"8dp"}'
            app:paddingLeftWithSystemWindowInsets='@{@dimen/small_padding}'
            app:paddingRightWithSystemWindowInsets='@{@dimen/small_padding}'
            android:paddingBottom="12dp"
            />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/route_profile_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scrollbars="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gem_surface_view"
            app:layout_constraintVertical_weight="0.5"
            app:paddingBottomWithSystemWindowInsets="@{@dimen/no_extra_inset}"
            app:paddingLeftWithSystemWindowInsets="@{@dimen/no_extra_inset}"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.github.mikephil.charting.charts.CombinedChart
                    android:id="@+id/elevation_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/elevation_chart_height"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:paddingTop="@dimen/big_padding" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/buttons_container"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_container_height"
                    android:layout_margin="@dimen/big_padding" />

                <TextView
                    android:id="@+id/climb_details_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size"
                    android:textStyle="bold" />

                <com.magiclane.sdk.examples.routeterrainprofile.SortableClimbTableView
                    android:id="@+id/table_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:scrollbars="none" />

                <TextView
                    android:id="@+id/surfaces_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/highlighted_surface"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size" />

                <com.github.mikephil.charting.charts.CombinedChart
                    android:id="@+id/surfaces_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_container_height"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding" />

                <TextView
                    android:id="@+id/roads_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/highlighted_road"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size" />

                <com.github.mikephil.charting.charts.CombinedChart
                    android:id="@+id/roads_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_container_height"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding" />

                <TextView
                    android:id="@+id/steepness_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:textSize="@dimen/small_text_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/steepness_image"
                        android:layout_width="@dimen/steepness_icon_size"
                        android:layout_height="@dimen/steepness_icon_size"
                        android:adjustViewBounds="true"
                        android:scaleType="centerInside"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:id="@+id/highlighted_steepness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/big_padding"
                        android:textSize="@dimen/small_text_size" />

                </LinearLayout>

                <com.github.mikephil.charting.charts.CombinedChart
                    android:id="@+id/steepness_chart"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_container_height"
                    android:layout_marginStart="@dimen/big_padding"
                    android:layout_marginEnd="@dimen/big_padding"
                    android:layout_marginBottom="@dimen/big_padding" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/gem_surface_view"
            app:layout_constraintEnd_toEndOf="@id/gem_surface_view"
            app:layout_constraintStart_toStartOf="@id/gem_surface_view"
            app:layout_constraintTop_toTopOf="@id/gem_surface_view" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
